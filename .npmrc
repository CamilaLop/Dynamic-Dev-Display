auto-install-peers=false
strict-peer-dependencies=false

# Install optional deps for all platforms (cross-platform dev)
# so esbuild + rollup binaries work on Replit (Linux) and local Mac
dedupe-peer-dependents=true
ignore-workspace-root-check=true

# Ensure native binaries for both Linux (Replit) and macOS are installed
# regardless of the host OS running pnpm install
supportedArchitectures.os=linux,darwin
supportedArchitectures.cpu=x64,arm64
